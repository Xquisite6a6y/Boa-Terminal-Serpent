# BOA environment template.
# Copy values into AWS App Runner / Elastic Beanstalk environment variables.
# Do not commit real secrets. Do not paste real secret values into chat.

# Public BOA site URL. Set this to the HTTPS URL AWS gives you.
BOA_BASE_URL=https://your-boa-app.example.com

# Demo-only JSON state path. Use persistent storage for production customer data.
BOA_STATE_PATH=/tmp/boa-state.json

# AWS normally sets PORT automatically. Local fallback is 8787.
PORT=8787
BOA_SITE_HOST=0.0.0.0

# Stripe backend key. Use a restricted key if it can create Checkout Sessions;
# otherwise use a test secret key while finishing setup.
# Never use the publishable/public key here.
STRIPE_SECRET_KEY=rk_test_REDACTED_OR_sk_test_REDACTED

# Stripe Price IDs, not API keys. They usually start with price_.
STRIPE_PRICE_SOLO=price_REDACTED_SOLO
STRIPE_PRICE_TEAM=price_REDACTED_TEAM
STRIPE_PRICE_ENTERPRISE=price_REDACTED_ENTERPRISE


# AWS deployment variables for local maintainer deploys or GitHub repository Variables.
# Do not commit access keys. Prefer GitHub OIDC with AWS_ROLE_TO_ASSUME.
AWS_REGION=us-east-1
APP_RUNNER_SERVICE_ARN=arn:aws:apprunner:REGION:ACCOUNT_ID:service/SERVICE_NAME/SERVICE_ID
AWS_ROLE_TO_ASSUME=arn:aws:iam::ACCOUNT_ID:role/GitHubBoaDeployRole
# Optional local-only alternatives, never committed with real values:
# AWS_PROFILE=boa-deploy
# AWS_ACCESS_KEY_ID=REDACTED
# AWS_SECRET_ACCESS_KEY=REDACTED
