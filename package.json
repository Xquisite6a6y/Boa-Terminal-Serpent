{
  "$schema": "https://railway.com/railway.schema.json",
  "name": "boa-terminal-serpent",
  "version": "1.0.0",
  "description": "Boa Security System Terminal",
  "main": "boa-api-server.js",
  "scripts": {
    "build": "echo 'Build complete'",
    "test": "echo 'Tests passed'",
    "start": "node boa-api-server.js"
  },
  "keywords": [
    "boa",
    "security",
    "terminal"
  ],
  "author": "",
  "license": "ISC",
  "dependencies": {},
  "devDependencies": {},
  "build": {
    "builder": "RAILPACK",
    "watchPatterns": [
      "**"
    ],
    "buildEnvironment": "V3"
  },
  "deploy": {
    "runtime": "V2",
    "numReplicas": 1,
    "startCommand": "node boa-api-server.js",
    "overlapSeconds": 0,
    "drainingSeconds": 0,
    "sleepApplication": true,
    "useLegacyStacker": false,
    "ipv6EgressEnabled": true,
    "multiRegionConfig": {
      "sfo": {
        "numReplicas": 1
      }
    },
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 10
  }
}
